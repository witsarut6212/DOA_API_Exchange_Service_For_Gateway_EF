{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "e-Phyto Progress Reject Schema (REJECT)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "documentControl",
    "details"
  ],
  "properties": {
    "documentControl": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "referenceNumber",
        "responseInfo",
        "messageType",
        "remark",
        "registrationId",
        "itemNumber",
        "reasonCode",
        "reasonDescription"
      ],
      "properties": {
        "referenceNumber": { "type": "string", "maxLength": 35, "minLength": 1 },
        "documentNumber": { "type": "string", "maxLength": 35 },
        "responseInfo": {
          "type": "object",
          "additionalProperties": false,
          "required": [ "dateTime", "status", "code" ],
          "properties": {
            "dateTime": { "type": "string", "format": "date-time" },
            "status": { "type": "string", "enum": ["REJECT"], "maxLength": 6 },
            "code": { "type": "string", "maxLength": 10 }
          }
        },
        "messageType": { "type": "string", "maxLength": 35 },
        "remark": { "type": "string", "maxLength": 200 },
        "registrationId": { "type": "string", "maxLength": 35 },
        "itemNumber": { "type": "integer", "minimum": 0, "maximum": 99 },
        "reasonCode": { "type": "string", "maxLength": 10 },
        "reasonDescription": { "type": "string", "maxLength": 256 }
      }
    },
    "details": {
      "type": "array",
      "minItems": 1,
      "maxItems": 99,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [ "itemNumber", "reasonCode", "reasonDescription" ],
        "properties": {
          "itemNumber": { "type": "integer", "minimum": 0, "maximum": 99 },
          "reasonCode": { "type": "string", "maxLength": 10 },
          "reasonDescription": { "type": "string", "maxLength": 256 }
        }
      }
    }
  }
}
