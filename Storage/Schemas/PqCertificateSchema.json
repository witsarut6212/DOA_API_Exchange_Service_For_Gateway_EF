{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PQ Certificate Request Schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "DocumentControl",
    "Details"
  ],
  "properties": {
    "DocumentControl": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ReferenceNumber",
        "DocumentFunctionCode",
        "FormType",
        "ReplacementForm",
        "SubmitForm",
        "CertificateStatus",
        "RegistrationID",
        "Applicant",
        "ConsignorExporter",
        "ConsigneeImporter",
        "ShipmentInfo",
        "InspectionInfo"
      ],
      "properties": {
        "ReferenceNumber": { "type": "string", "minLength": 1 },
        "DocumentFunctionCode": { "type": "string", "minLength": 1 },
        "FormType": { "type": "string", "enum": ["pq7", "pq8", "pq9"] },
        "ReplacementForm": { "type": "string" },
        "SubmitForm": {
          "type": "object",
          "additionalProperties": false,
          "required": ["Date"],
          "properties": {
            "Date": { "type": "string", "minLength": 1 }
          }
        },
        "CertificateStatus": { "type": "string", "enum": ["Draft", "draft"] },
        "RegistrationID": { "type": "string" },
        "Applicant": {
          "type": "object",
          "additionalProperties": false,
          "required": ["Id", "IdType", "Name"],
          "properties": {
            "Id": { "type": "string", "minLength": 1 },
            "IdType": { "type": "string", "minLength": 1 },
            "Name": { "type": "string", "minLength": 1 },
            "StreetAndNumber": { "type": ["string", "null"] },
            "District": { "type": ["string", "null"] },
            "SubProvice": { "type": ["string", "null"] },
            "City": { "type": ["string", "null"] },
            "Postcode": { "type": ["string", "null"] },
            "PhoneNumber": { "type": ["string", "null"] },
            "FaxNumber": { "type": ["string", "null"] },
            "Email": { "type": ["string", "null"] },
            "AttorneyIDCard": { "type": ["string", "null"] },
            "AttorneyName": { "type": ["string", "null"] }
          }
        },
        "ConsignorExporter": {
          "type": "object",
          "additionalProperties": false,
          "required": ["TaxNumber", "CompanyName"],
          "properties": {
            "TaxNumber": { "type": "string", "minLength": 1 },
            "CompanyName": { "type": "string", "minLength": 1 },
            "AttorneyIDCard": { "type": ["string", "null"] },
            "StreetAndNumber": { "type": ["string", "null"] },
            "SubDistrict": { "type": ["string", "null"] },
            "City": { "type": ["string", "null"] },
            "Postcode": { "type": ["string", "null"] },
            "CountryCode": { "type": ["string", "null"] },
            "PhoneNumber": { "type": ["string", "null"] },
            "FaxNumber": { "type": ["string", "null"] },
            "Email": { "type": ["string", "null"] }
          }
        },
        "OnBeHalfCareOf": {
          "type": ["object", "null"],
          "additionalProperties": false,
          "properties": {
            "Code": { "type": ["string", "null"] },
            "CompanyName": { "type": ["string", "null"] },
            "AddrressLine1": { "type": ["string", "null"] },
            "AddrressLine2": { "type": ["string", "null"] },
            "City": { "type": ["string", "null"] },
            "StateProvince": { "type": ["string", "null"] },
            "Postcode": { "type": ["string", "null"] },
            "CountryCode": { "type": ["string", "null"] },
            "PhoneNumber": { "type": ["string", "null"] },
            "FaxNumber": { "type": ["string", "null"] },
            "Email": { "type": ["string", "null"] }
          }
        },
        "ConsigneeImporter": {
          "type": "object",
          "additionalProperties": false,
          "required": ["CompanyName"],
          "properties": {
            "TaxNumber": { "type": ["string", "null"] },
            "CompanyName": { "type": "string", "minLength": 1 },
            "AddrressLine1": { "type": ["string", "null"] },
            "AddrressLine2": { "type": ["string", "null"] },
            "City": { "type": ["string", "null"] },
            "StateProvince": { "type": ["string", "null"] },
            "Postcode": { "type": ["string", "null"] },
            "CountryCode": { "type": ["string", "null"] },
            "PhoneNumber": { "type": ["string", "null"] },
            "FaxNumber": { "type": ["string", "null"] },
            "Email": { "type": ["string", "null"] }
          }
        },
        "ShipmentInfo": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "Transportation",
            "DestinationCountry",
            "DischargePort",
            "LoadingPort",
            "DepartureOnBoard",
            "TotalAmount",
            "TotalPackage",
            "GrossWeight",
            "NetWeight",
            "PlaceOriginCountry"
          ],
          "properties": {
            "Transportation": {
              "type": "object",
              "additionalProperties": false,
              "required": ["ModeCode", "VesselName", "BillNumber"],
              "properties": {
                "ModeCode": { "type": "string", "minLength": 1 },
                "VesselName": { "type": "string", "minLength": 1 },
                "BillNumber": { "type": "string", "minLength": 1 }
              }
            },
            "DestinationCountry": { "type": "string", "minLength": 1 },
            "DischargePort": {
              "type": "object",
              "additionalProperties": false,
              "required": ["Code", "Name"],
              "properties": {
                "Code": { "type": "string", "minLength": 1 },
                "Name": { "type": "string", "minLength": 1 }
              }
            },
            "LoadingPort": {
              "type": "object",
              "additionalProperties": false,
              "required": ["Code", "Name"],
              "properties": {
                "Code": { "type": "string", "minLength": 1 },
                "Name": { "type": "string", "minLength": 1 }
              }
            },
            "DepartureOnBoard": {
              "type": "object",
              "additionalProperties": false,
              "required": ["Date"],
              "properties": {
                "Date": { "type": "string", "minLength": 1 }
              }
            },
            "TotalAmount": {
              "type": "object",
              "additionalProperties": false,
              "required": ["Amount", "CurrencyCode"],
              "properties": {
                "Amount": { "type": "number" },
                "CurrencyCode": { "type": "string", "minLength": 1 }
              }
            },
            "TotalPackage": {
              "type": "object",
              "additionalProperties": false,
              "required": ["Quantity", "TypeCode"],
              "properties": {
                "Quantity": { "type": "number" },
                "TypeCode": { "type": "string", "minLength": 1 }
              }
            },
            "GrossWeight": {
              "type": "object",
              "additionalProperties": false,
              "required": ["Weight", "UnitCode"],
              "properties": {
                "Weight": { "type": "number" },
                "UnitCode": { "type": "string", "minLength": 1 }
              }
            },
            "NetWeight": {
              "type": "object",
              "additionalProperties": false,
              "required": ["Weight", "UnitCode"],
              "properties": {
                "Weight": { "type": "number" },
                "UnitCode": { "type": "string", "minLength": 1 }
              }
            },
            "PlaceOriginCountry": { "type": "string", "minLength": 1 }
          }
        },
        "InspectionInfo": {
          "type": "object",
          "additionalProperties": false,
          "required": ["IssueLocationCode", "OperateType", "PlaceCode", "Due"],
          "properties": {
            "IssueLocationCode": { "type": "string", "minLength": 1 },
            "OperateType": { "type": "string", "minLength": 1 },
            "PlaceCode": { "type": "string", "minLength": 1 },
            "Due": {
              "type": "object",
              "additionalProperties": false,
              "required": ["DateTimeString"],
              "properties": {
                "DateTimeString": { "type": "string", "minLength": 1 }
              }
            }
          }
        }
      }
    },
    "Details": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "ItemNumber",
          "TradeDescrition",
          "CommonName",
          "ScientificName",
          "ProductCode",
          "TariffInfo",
          "ThaiGoodsDescrition",
          "NetWeight",
          "Quantityinfo",
          "PhysicalPackage",
          "AmountInfo",
          "Packaging",
          "ObjectiveCode",
          "SendLab",
          "AdditionalDescription",
          "ACFSCollaboration",
          "OriginCountries"
        ],
        "properties": {
          "ItemNumber": { "type": "integer" },
          "TradeDescrition": { "type": "string", "minLength": 1 },
          "CommonName": { "type": "string", "minLength": 1 },
          "ScientificName": { "type": "string", "minLength": 1 },
          "ProductCode": { "type": "string", "minLength": 1 },
          "TariffInfo": {
            "type": "object",
            "additionalProperties": false,
            "required": ["Code", "Statistical"],
            "properties": {
              "Code": { "type": "string", "minLength": 1 },
              "Statistical": { "type": "string", "minLength": 1 }
            }
          },
          "ThaiGoodsDescrition": { "type": "string", "minLength": 1 },
          "NetWeight": {
            "type": "object",
            "additionalProperties": false,
            "required": ["Weight", "UnitCode"],
            "properties": {
              "Weight": { "type": "number" },
              "UnitCode": { "type": "string", "minLength": 1 }
            }
          },
          "Quantityinfo": {
            "type": "object",
            "additionalProperties": false,
            "required": ["Quantity", "TypeCode"],
            "properties": {
              "Quantity": { "type": "number" },
              "TypeCode": { "type": "string", "minLength": 1 }
            }
          },
          "PhysicalPackage": {
            "type": "object",
            "additionalProperties": false,
            "required": ["LevelCode", "Quantity", "UnitCode"],
            "properties": {
              "LevelCode": { "type": "integer" },
              "Quantity": { "type": "number" },
              "UnitCode": { "type": "string", "minLength": 1 }
            }
          },
          "AmountInfo": {
            "type": "object",
            "additionalProperties": false,
            "required": ["Value", "CurrencyCode"],
            "properties": {
              "Value": { "type": "number" },
              "CurrencyCode": { "type": "string", "minLength": 1 }
            }
          },
          "Remark": { "type": ["string", "null"] },
          "Packaging": { "type": "integer" },
          "ObjectiveCode": { "type": "integer" },
          "SendLab": { "type": "integer" },
          "AdditionalDescription": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "Lab": { "type": ["string", "null"] },
              "Product": { "type": ["string", "null"] }
            }
          },
          "ACFSCollaboration": { "type": "integer" },
          "OriginCountries": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["ItemNumber", "CountryCode", "IssueDate", "ItemReferenceDocument"],
              "properties": {
                "ItemNumber": { "type": "integer" },
                "CountryCode": { "type": "string", "minLength": 1 },
                "RegistrationNumber": { "type": ["string", "null"] },
                "LocationName": { "type": ["string", "null"] },
                "IssueDate": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["Date"],
                  "properties": {
                    "Date": { "type": "string", "minLength": 1 }
                  }
                },
                "Remark": { "type": ["string", "null"] },
                "ItemReferenceDocument": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["ItemNumber", "DocumentNumber", "DocumentType", "ProviderAuthority", "Issued", "Expire", "Attachment"],
                  "properties": {
                    "ItemNumber": { "type": "integer" },
                    "DocumentNumber": { "type": "string", "minLength": 1 },
                    "DocumentType": {
                      "type": "object",
                      "additionalProperties": false,
                      "required": ["Code", "Name"],
                      "properties": {
                        "Code": { "type": "string", "minLength": 1 },
                        "Name": { "type": "string", "minLength": 1 }
                      }
                    },
                    "ProviderAuthority": {
                      "type": "object",
                      "additionalProperties": false,
                      "required": ["TaxNumber"],
                      "properties": {
                        "TaxNumber": { "type": "string", "minLength": 1 }
                      }
                    },
                    "Issued": {
                      "type": "object",
                      "additionalProperties": false,
                      "required": ["Date"],
                      "properties": {
                        "Date": { "type": "string", "minLength": 1 }
                      }
                    },
                    "Expire": {
                      "type": "object",
                      "additionalProperties": false,
                      "required": ["Date"],
                      "properties": {
                        "Date": { "type": "string", "minLength": 1 }
                      }
                    },
                    "Attachment": {
                      "type": "object",
                      "additionalProperties": false,
                      "required": ["Filename", "FileID", "FleUrl"],
                      "properties": {
                        "Filename": { "type": "string", "minLength": 1 },
                        "FileID": { "type": "string", "minLength": 1 },
                        "FleUrl": { "type": "string", "minLength": 1 }
                      }
                    },
                    "Remark": { "type": ["string", "null"] }
                  }
                }
              }
            }
          },
          "Treatments": {
            "type": ["array", "null"],
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["ItemNumber", "Method", "CompletionPeriod"],
              "properties": {
                "ItemNumber": { "type": "integer" },
                "Method": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["TypeCode", "Description"],
                  "properties": {
                    "TypeCode": { "type": "string", "minLength": 1 },
                    "Description": { "type": "string", "minLength": 1 }
                  }
                },
                "CompletionPeriod": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["StartDateTime"],
                  "properties": {
                    "StartDateTime": { "type": "string", "minLength": 1 }
                  }
                },
                "Chemical": { "type": ["string", "null"] },
                "DurationMeasure": {
                  "type": ["object", "null"],
                  "additionalProperties": false,
                  "properties": {
                    "Duration": { "type": "number" },
                    "UnitCode": { "type": "string" }
                  }
                },
                "Temperature": {
                  "type": ["object", "null"],
                  "additionalProperties": false,
                  "properties": {
                    "ValueMeasure": { "type": "string" },
                    "UnitCode": { "type": "string" }
                  }
                },
                "Concentration": {
                  "type": ["object", "null"],
                  "additionalProperties": false,
                  "properties": {
                    "ValueMeasure": { "type": "string" },
                    "UnitCode": { "type": "string" }
                  }
                },
                "Remark": { "type": ["string", "null"] }
              }
            }
          },
          "AdditionalDeclarations": {
            "type": ["array", "null"],
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["ItemNumber", "SubjectCode", "Description"],
              "properties": {
                "ItemNumber": { "type": "integer" },
                "SubjectCode": { "type": "string", "minLength": 1 },
                "Description": { "type": "string", "minLength": 1 },
                "AdditionalReferenceDocuments": {
                  "type": ["array", "null"],
                  "items": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": ["DocumentType"],
                    "properties": {
                      "DocumentType": {
                        "type": "object",
                        "additionalProperties": false,
                        "required": ["Code", "Name"],
                        "properties": {
                          "Code": { "type": "string", "minLength": 1 },
                          "Name": { "type": "string", "minLength": 1 }
                        }
                      },
                      ".Attachment": {
                        "type": ["object", "null"],
                        "additionalProperties": false,
                        "properties": {
                          "Filename": { "type": "string" },
                          "FileID": { "type": "string" },
                          "FleUrl": { "type": "string" }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "ThirdPartyFumigations": {
      "type": ["array", "null"],
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["Due"],
        "properties": {
          "FirstName": { "type": ["string", "null"] },
          "LastName": { "type": ["string", "null"] },
          "CompanyCode": { "type": ["string", "null"] },
          "LocationName": { "type": ["string", "null"] },
          "StreetAndNumber": { "type": ["string", "null"] },
          "SubDistrict": { "type": ["string", "null"] },
          "District": { "type": ["string", "null"] },
          "City": { "type": ["string", "null"] },
          "Postcode": { "type": ["string", "null"] },
          "PhoneNumber": { "type": ["string", "null"] },
          "FaxNumber": { "type": ["string", "null"] },
          "Email": { "type": ["string", "null"] },
          "Due": {
            "type": "object",
            "additionalProperties": false,
            "required": ["DateTimeString"],
            "properties": {
              "DateTimeString": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    },
    "TransitCountries": {
      "type": ["array", "null"],
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["CountryCode"],
        "properties": {
          "CountryCode": { "type": "string", "minLength": 1 },
          "City": { "type": ["string", "null"] },
          "PortCode": { "type": ["string", "null"] },
          "Remark": { "type": ["string", "null"] }
        }
      }
    },
    "Containers": {
      "type": ["array", "null"],
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["Number", "SealNumber"],
        "properties": {
          "Number": { "type": "string", "minLength": 1 },
          "SealNumber": { "type": "string", "minLength": 1 }
        }
      }
    },
    "ShippingMarks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["Marking"],
        "properties": {
          "Marking": { "type": "string", "minLength": 1 }
        }
      }
    },
    "ReferenceDocuments": {
      "type": ["array", "null"],
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["ItemNumber", "DocumentNumber", "DocumentType", "DetailItemNumber", "ProviderAuthority", "Issued", "Expire", "Attachment"],
        "properties": {
          "ItemNumber": { "type": "integer" },
          "DocumentNumber": { "type": "string", "minLength": 1 },
          "CocumentType": {
            "type": "object",
            "additionalProperties": false,
            "required": ["Code", "Name"],
            "properties": {
              "Code": { "type": "string", "minLength": 1 },
              "Name": { "type": "string", "minLength": 1 }
            }
          },
          "DetailItemNumber": { "type": "integer" },
          "ProviderAuthority": {
            "type": "object",
            "additionalProperties": false,
            "required": ["TaxNumber"],
            "properties": {
              "TaxNumber": { "type": "string", "minLength": 1 }
            }
          },
          "Issued": {
            "type": "object",
            "additionalProperties": false,
            "required": ["Date"],
            "properties": {
              "Date": { "type": "string", "minLength": 1 }
            }
          },
          "Expire": {
            "type": "object",
            "additionalProperties": false,
            "required": ["Date"],
            "properties": {
              "Date": { "type": "string", "minLength": 1 }
            }
          },
          "Attachment": {
            "type": "object",
            "additionalProperties": false,
            "required": ["Filename", "FileId", "FileUrl"],
            "properties": {
              "Filename": { "type": "string", "minLength": 1 },
              "FileId": { "type": "string", "minLength": 1 },
              "FileUrl": { "type": "string", "minLength": 1 }
            }
          },
          "Remark": { "type": ["string", "null"] }
        }
      }
    }
  }
}
