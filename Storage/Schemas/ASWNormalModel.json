{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ASW e-Phyto Normal Case Schema (New Version)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "detail",
    "doc_name",
    "doc_id",
    "doc_type",
    "doc_status",
    "exporter_name",
    "consignee_name",
    "export_country_code",
    "import_country_code"
  ],
  "properties": {
    "detail": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "item_no": { "type": ["integer", "number"] },
          "descriptions": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": { "name": { "type": "string" } },
              "required": ["name"]
            }
          },
          "product_name": { "type": ["string", "null"] },
          "product_scient_name": { "type": ["string", "null"] },
          "product_batch_id": { "type": ["string", "null"] },
          "product_intended_use": { "type": ["string", "null"] },
          "net_weight": { "type": ["number", "integer"] },
          "net_weight_unit": { "type": ["string", "null"] },
          "gross_weight": { "type": ["number", "integer"] },
          "gross_weight_unit": { "type": ["string", "null"] },
          "package_level": { "type": ["string", "null"] },
          "package_type": { "type": ["string", "null"] },
          "package_amount": { "type": ["integer", "number"] },
          "shipping_marks": { "type": ["string", "null"] },
          "producer_location_code": { "type": ["string", "null"] },
          "producer_location_name": { "type": ["string", "null"] },
          "additionals": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "note_subject": { "type": "string" },
                "note_content": { "type": "string" }
              }
            }
          },
          "classifications": { "type": ["array", "null"] },
          "transport_equipments": { "type": ["array", "null"] },
          "origin_countries": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "origin_country_code": { "type": ["string", "null"] },
                "origin_country_name": { "type": ["string", "null"] },
                "origin_province_code": { "type": ["string", "null"] },
                "origin_province_name": { "type": ["string", "null"] },
                "origin_hierarchi_level": { "type": ["string", "null"] },
                "producer_code": { "type": ["string", "null"] },
                "producer_name": { "type": ["string", "null"] },
                "producer_role": { "type": ["string", "null"] }
              }
            }
          },
          "processes": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "process_type": { "type": ["string", "null"] },
                "process_start_date": { "type": ["string", "null"] },
                "process_end_date": { "type": ["string", "null"] },
                "process_duration": { "type": ["number", "integer", "null"] },
                "process_duration_unit": { "type": ["string", "null"] },
                "characteristics": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "process_character_code": { "type": ["string", "null"] },
                      "process_character_desc": { "type": ["string", "null"] },
                      "process_value": { "type": ["string", "number", "null"] },
                      "process_value_unit": { "type": ["string", "null"] }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "doc_name": { "type": ["string", "null"] },
    "doc_id": { "type": ["string", "null"], "maxLength": 60 },
    "doc_description": { "type": ["string", "null"] },
    "doc_type": { "type": ["string", "null"] },
    "doc_status": { "type": ["string", "null"] },
    "issuer_id": { "type": ["string", "null"] },
    "issuer_name": { "type": ["string", "null"] },
    "ref_issue_datetime": { "type": ["string", "null"] },
    "ref_type": { "type": ["string", "null"] },
    "ref_relation": { "type": ["string", "null"] },
    "ref_id": { "type": ["string", "null"] },
    "ref_info": { "type": ["string", "null"] },
    "auth_location_id": { "type": ["string", "null"] },
    "auth_location_name": { "type": ["string", "null"] },
    "auth_provider_id": { "type": ["string", "null"] },
    "auth_provider_name": { "type": ["string", "null"] },
    "auth_person": { "type": ["string", "null"] },
    "auth_position_name": { "type": ["string", "null"] },
    "auth_position_abb": { "type": ["string", "null"] },
    "exporter_name": { "type": ["string", "null"] },
    "exporter_line1": { "type": ["string", "null"] },
    "exporter_line2": { "type": ["string", "null"] },
    "exporter_line3": { "type": ["string", "null"] },
    "exporter_line4": { "type": ["string", "null"] },
    "exporter_line5": { "type": ["string", "null"] },
    "exporter_city_name": { "type": ["string", "null"] },
    "exporter_post_code": { "type": ["string", "null"] },
    "exporter_country_code": { "type": ["string", "null"] },
    "exporter_country_name": { "type": ["string", "null"] },
    "exporter_address_type": { "type": ["string", "null"] },
    "consignee_name": { "type": ["string", "null"] },
    "consignee_line1": { "type": ["string", "null"] },
    "consignee_line2": { "type": ["string", "null"] },
    "consignee_line3": { "type": ["string", "null"] },
    "consignee_line4": { "type": ["string", "null"] },
    "consignee_line5": { "type": ["string", "null"] },
    "consignee_city_name": { "type": ["string", "null"] },
    "consignee_post_code": { "type": ["string", "null"] },
    "consignee_country_code": { "type": ["string", "null"] },
    "export_country_code": { "type": ["string", "null"] },
    "export_country_name": { "type": ["string", "null"] },
    "reexport_country_code": { "type": ["string", "null"] },
    "reexport_country_name": { "type": ["string", "null"] },
    "import_country_code": { "type": ["string", "null"] },
    "import_country_name": { "type": ["string", "null"] },
    "unloading_port_code": { "type": ["string", "null"] },
    "unloading_port_name": { "type": ["string", "null"] },
    "transport_mode": { "type": ["string", "null"] },
    "vessel_number": { "type": ["string", "null"] },
    "vessel_name": { "type": ["string", "null"] },
    "notes": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "note_subject_code": { "type": "string" },
          "note_content": { "type": "string" }
        }
      }
    },
    "clauses": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "clause_id": { "type": "integer" },
          "clause_content": { "type": "string" }
        }
      }
    },
    "transits": { "type": "array" }
  }
}
